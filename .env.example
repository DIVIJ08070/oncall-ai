# OnCall AI — environment template (full config contract, SPEC §14).
# Copy this file to `.env` and adjust as needed. `.env` is git-ignored.
#
# Every key below maps 1:1 to `packages/server/src/config.ts` (the zod EnvSchema).
# Values shown are the built-in defaults, so a plain `cp .env.example .env` boots a
# working local stack. Secrets/optional keys are left blank on purpose. Blank ==
# "unset" (the loader treats empty strings as absent and applies the default).

# ── AI agent (real Claude tool-use loop, SPEC §9) ────────────────────
# The investigation agent authenticates via the local Claude Max subscription
# (Claude Agent SDK) — keep this true for the real-Claude path.
USE_CLAUDE_SUBSCRIPTION=true
# NOTE: ANTHROPIC_API_KEY is currently UNUSED. The agent authenticates through the
# Claude Max subscription (USE_CLAUDE_SUBSCRIPTION=true), not this key. Whether an
# investigation runs live or from the deterministic cache is governed by AGENT_MODE
# (below), NOT by the presence/absence of this key. Left blank by default.
ANTHROPIC_API_KEY=
# Model id the agent loop uses.
AGENT_MODEL=claude-sonnet-5
# Investigation engine selector: auto (live if available, else cached) | live | cached.
AGENT_MODE=auto
# Safety caps for the agent loop (SPEC §9).
AGENT_MAX_ITERATIONS=10
AGENT_CONFIDENCE_THRESHOLD=0.6
AGENT_COST_CAP_USD=0.25
# Record real-PR investigations into the cache for deterministic replay (SPEC §13).
CACHE_REAL_PR=true

# ── GitHub (real PR delivery + repo read) ────────────────────────────
# Fine-grained Personal Access Token scoped to the demo victim repo ONLY, with
# Contents (read/write) + Pull requests (read/write). Blank disables the merge
# poller / real-PR path.
GITHUB_TOKEN=
# The demo "victim" app repo that fixes are proposed against (owner / repo).
GITHUB_OWNER=DIVIJ08070
GITHUB_REPO=oncall-ai-victim
# Branch the victim repo is seeded on and PRs target.
GITHUB_DEFAULT_BRANCH=main
# Branches the agent may never push to directly (comma-separated SAFETY guard, §9).
GITHUB_PROTECTED_BRANCHES=main,master

# ── GitHub OAuth (onboarding sign-in, FR-15) ─────────────────────────
# From a GitHub OAuth App. Leave blank if onboarding OAuth is deferred
# (build/QA against DEV_NO_AUTH=true until real creds arrive).
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── Log ingestion (FR-01, per-customer API key) ──────────────────────
# Credential the ingest endpoint authenticates (x-ingest-key header). `npm run seed`
# ensures a demo customer keyed on this value.
INGEST_API_KEY=dev-local-ingest-key

# ── Notifications (Slack stub, FR-17 — optional) ─────────────────────
# Incoming-webhook URL for incident notifications. Blank disables Slack posts.
SLACK_WEBHOOK_URL=

# ── Server / auth (SPEC §14) ─────────────────────────────────────────
PORT=3001
DATABASE_URL=./data/oncall.sqlite
# Public base URL the platform advertises (used to build the ingest URL, etc.).
PUBLIC_BASE_URL=http://localhost:3001
# Where the dashboard front-end is served (CORS + OAuth redirect target).
DASHBOARD_URL=http://localhost:5173
# Session signing secret — CHANGE THIS for any non-local deployment.
SESSION_SECRET=dev-secret-change-me
# Bypass OAuth for local dev (treat requests as the seeded demo customer).
DEV_NO_AUTH=true

# ── Detection engine (SPEC §10, FR-05/06/19) ─────────────────────────
# Rollup/detection loop cadence.
DETECTION_INTERVAL_MS=15000
# Error-rate threshold (0..1) that opens an incident.
ERROR_RATE_THRESHOLD=0.2
# Minimum requests in a window before detection fires (avoids low-volume noise).
MIN_REQUESTS_FOR_DETECTION=5
# p95 latency threshold (ms) that opens a latency incident.
LATENCY_P95_THRESHOLD_MS=1000
# No-telemetry silence window (ms) before a silence incident opens.
SILENCE_WINDOW_MS=60000
# Healthy window (ms) required after a merge before recovery is confirmed.
RECOVERY_WINDOW_MS=60000
# How often the merge poller checks the PR for a merge (ms).
MERGE_POLL_INTERVAL_MS=5000

# ── Victim app (SPEC §11/§12) ────────────────────────────────────────
# Port the demo victim app listens on.
VICTIM_PORT=4000
# Victim control plane URL (demo failure-mode / traffic toggles).
VICTIM_CONTROL_URL=http://localhost:4000
# Where the victim ships its telemetry (the platform ingest endpoint).
ONCALL_INGEST_URL=http://localhost:3001/api/v1/ingest
# Ingest key the victim uses — must match INGEST_API_KEY above.
ONCALL_API_KEY=dev-local-ingest-key
