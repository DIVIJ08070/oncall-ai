# OnCall AI — environment template.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# The architect will finalize this contract; these are the credentials the
# human must supply for the real-GitHub + real-Claude path.

# ── AI agent (real Claude tool-use loop) ─────────────────────────────
# Anthropic API key for the investigation agent. If absent, the platform
# falls back to cached/deterministic investigation replay (BRD NFR-09).
ANTHROPIC_API_KEY=

# ── GitHub (real PR delivery + repo read) ────────────────────────────
# Fine-grained Personal Access Token scoped to the demo victim repo ONLY,
# with Contents (read/write) + Pull requests (read/write) permissions.
GITHUB_TOKEN=
# The demo "victim" app repo that fixes are proposed against, as owner/repo.
GITHUB_OWNER=
GITHUB_REPO=

# ── GitHub OAuth (onboarding sign-in, FR-15) ─────────────────────────
# From a GitHub OAuth App. Leave blank if onboarding OAuth is deferred.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── Log ingestion (FR-01, per-customer API key) ──────────────────────
INGEST_API_KEY=dev-local-ingest-key

# ── Notifications (Slack stub, FR-17 — optional) ─────────────────────
SLACK_WEBHOOK_URL=

# ── Runtime ──────────────────────────────────────────────────────────
PORT=3001
DATABASE_URL=./data/oncall.sqlite
