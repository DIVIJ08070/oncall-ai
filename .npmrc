# The Claude Agent SDK (@anthropic-ai/claude-agent-sdk, C7) declares a peer dep on
# zod ^4, while this workspace is pinned to zod ^3.23 (SPEC §2 — one schema source
# across shared/server/agent). zod 3 satisfies the SDK at runtime (tool() only reads
# the raw shape), so we relax peer resolution instead of forking the whole repo to
# zod 4. Keeps a bare `npm install` reproducible for CI/QA.
legacy-peer-deps=true
