{
  "name": "@oncall/agent",
  "version": "0.1.0",
  "private": true,
  "description": "@oncall/agent — investigation tools (six + submit_findings), SAFETY guards, and bounded-output caps over Octokit + DB (SPEC §9). Engine/loop land in C7/C8.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@oncall/shared": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@octokit/rest": "^21.1.1"
  }
}
