# @oncall/dashboard — Vite env template (copy to `.env.local`; git-ignored).
# The dashboard is served by Vite on :5173 and talks to the platform API.

# Platform base URL (SPEC §6/§14). The dashboard calls `${PUBLIC_BASE_URL}/api/v1`
# for fetch + SSE. Default when unset: http://localhost:3001
PUBLIC_BASE_URL=http://localhost:3001
