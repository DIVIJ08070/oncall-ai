{
  "name": "@oncall/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types + Zod schemas for OnCall AI (single source: validation + SDK tool typing).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
